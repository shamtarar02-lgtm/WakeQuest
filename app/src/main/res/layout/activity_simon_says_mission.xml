<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_background"
    android:padding="@dimen/spacing_xl">

    <TextView
        android:id="@+id/tvMissionTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/title_simon_mission"
        android:textColor="@color/color_text_primary"
        android:textSize="@dimen/text_size_title"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="@dimen/spacing_massive" />

    <TextView
        android:id="@+id/tvInstructions"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/instructions_simon"
        android:textColor="@color/color_text_secondary"
        android:textSize="@dimen/text_size_body_large"
        android:textAlignment="center"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvMissionTitle"
        android:layout_marginTop="@dimen/spacing_md" />

    <GridLayout
        android:id="@+id/glSimonGrid"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:columnCount="2"
        android:rowCount="2"
        android:layout_marginTop="@dimen/spacing_huge"
        app:layout_constraintBottom_toTopOf="@+id/btnStartSimon"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvInstructions">

        <View
            android:id="@+id/vRed"
            android:layout_width="@dimen/simon_tile_size"
            android:layout_height="@dimen/simon_tile_size"
            android:layout_margin="@dimen/spacing_xs"
            android:background="@color/color_simon_red" />

        <View
            android:id="@+id/vBlue"
            android:layout_width="@dimen/simon_tile_size"
            android:layout_height="@dimen/simon_tile_size"
            android:layout_margin="@dimen/spacing_xs"
            android:background="@color/color_simon_blue" />

        <View
            android:id="@+id/vGreen"
            android:layout_width="@dimen/simon_tile_size"
            android:layout_height="@dimen/simon_tile_size"
            android:layout_margin="@dimen/spacing_xs"
            android:background="@color/color_simon_green" />

        <View
            android:id="@+id/vYellow"
            android:layout_width="@dimen/simon_tile_size"
            android:layout_height="@dimen/simon_tile_size"
            android:layout_margin="@dimen/spacing_xs"
            android:background="@color/color_simon_yellow" />
    </GridLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnStartSimon"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/action_start_sequence"
        android:backgroundTint="@color/color_primary"
        android:layout_marginBottom="@dimen/spacing_massive"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
